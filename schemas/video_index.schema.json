{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Cuepoint 视频索引文档(video_index.json)",
  "description": "导出公开契约(spec v0.5 §6.5):大纲↔transcript↔frames 映射的自包含单文档。版本策略:加字段升次版本,删字段/改语义升主版本;消费方按主版本判兼容。运行期校验为 storyboard.py export 内的 stdlib 手写子集,本文件是规范本体,测试以 jsonschema(仅 dev 依赖)对拍防漂移。",
  "type": "object",
  "required": ["schema_version", "generator", "video", "transcript", "outline"],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "语义化版本"
    },
    "generator": {
      "type": "object",
      "required": ["skill"],
      "properties": {
        "skill": { "type": "string" },
        "spec": { "type": "string" }
      }
    },
    "video": {
      "type": "object",
      "required": ["platform", "title", "duration", "source_url", "badge_url_template", "visual_form", "priors"],
      "properties": {
        "platform": { "enum": ["youtube", "bilibili", "local"] },
        "title": { "type": "string" },
        "uploader": { "type": ["string", "null"] },
        "duration": { "type": "number", "exclusiveMinimum": 0 },
        "language": { "type": ["string", "null"] },
        "genre": { "type": ["string", "null"] },
        "source_url": {
          "type": ["string", "null"],
          "description": "在线平台为归一化 URL;本地文件为原始绝对路径(高清自取入口)"
        },
        "badge_url_template": {
          "type": ["string", "null"],
          "description": "时间戳跳转模板,{t} 占位整数秒;platform=local 时为 null"
        },
        "visual_form": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["t_start", "t_end", "form"],
            "properties": {
              "t_start": { "type": "number" },
              "t_end": { "type": "number" },
              "form": { "type": "string" }
            }
          }
        },
        "priors": { "type": "object", "description": "chapters/heatmap/danmaku_density/page_boundaries,均 fail-open 可空" }
      }
    },
    "transcript": {
      "type": "object",
      "required": ["source", "timestamp_granularity", "segments"],
      "properties": {
        "source": { "type": "string", "description": "manual:<lang>/auto:<lang>(字幕轨)或 asr:<backend>" },
        "timestamp_granularity": {
          "enum": ["segment", "sentence", "chunk-45s"],
          "description": "时间戳精度:字幕/transcriptions 家族=segment,funasr=sentence,chat 家族=chunk-45s(45s 块级,不得当秒级用)"
        },
        "segments": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "t_start", "t_end", "text"],
            "properties": {
              "id": { "type": "integer", "minimum": 0 },
              "t_start": { "type": "number", "minimum": 0 },
              "t_end": { "type": "number", "minimum": 0 },
              "text": { "type": "string" }
            }
          }
        }
      }
    },
    "outline": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/node" }
    }
  },
  "definitions": {
    "node": {
      "type": "object",
      "required": ["id", "level", "title", "summary", "t_start", "t_end", "evidence", "media", "children"],
      "properties": {
        "id": { "type": "string" },
        "level": { "type": "integer", "minimum": 1 },
        "title": { "type": "string" },
        "summary": { "type": "string" },
        "t_start": { "type": "number", "minimum": 0 },
        "t_end": { "type": "number", "minimum": 0 },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["segment_id", "quote"],
            "properties": {
              "segment_id": { "type": "integer", "description": "指向 transcript.segments[].id" },
              "quote": { "type": "string", "minLength": 1, "description": "所引段内一字不差的原文短语" }
            }
          }
        },
        "media": {
          "type": "array",
          "items": {
            "oneOf": [
              { "$ref": "#/definitions/frame" },
              { "$ref": "#/definitions/clip" }
            ]
          }
        },
        "children": {
          "type": "array",
          "items": { "$ref": "#/definitions/node" }
        }
      }
    },
    "frame": {
      "type": "object",
      "required": ["type", "path", "t", "resolution", "dedup_group", "dedup_primary"],
      "properties": {
        "type": { "const": "frame" },
        "path": { "type": "string", "pattern": "^frames/", "description": "相对文档所在目录" },
        "t": { "type": "number", "minimum": 0, "description": "帧时间戳(秒);高清自取 = source_url + t" },
        "resolution": { "type": "string", "description": "如 proxy-360p" },
        "score": { "type": ["number", "null"] },
        "reason": { "type": ["string", "null"] },
        "dedup_group": { "type": ["string", "null"], "description": "跨要点重复组标识;null=无重复" },
        "dedup_primary": { "type": "boolean", "description": "组内首选;组内恰一个 true" }
      }
    },
    "clip": {
      "type": "object",
      "required": ["type", "t_start", "t_end", "poster"],
      "properties": {
        "type": { "const": "clip" },
        "t_start": { "type": "number", "minimum": 0 },
        "t_end": { "type": "number", "minimum": 0 },
        "poster": { "type": ["string", "null"], "description": "poster 帧相对路径;clip 本体不物化(区间 + 源自取)" },
        "reason": { "type": ["string", "null"] }
      }
    }
  }
}
